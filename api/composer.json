{
  "name": "hux/conecta-crm-api",
  "description": "Conecta CRM — API PHP 8.2 multi-tenant",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "firebase/php-jwt": "^6.10",
    "vlucas/phpdotenv": "^5.6",
    "guzzlehttp/guzzle": "^7.8",
    "predis/predis": "^2.2",
    "ramsey/uuid": "^4.7",
    "league/csv": "^9.15",
    "respect/validation": "^2.3",
    "monolog/monolog": "^3.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "mockery/mockery": "^1.6",
    "fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "CRM\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CRM\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "php -l src/**/*.php"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
